# ── LangSmith Observability ──────────────────────────
# Set to "true" only when LANGCHAIN_API_KEY is configured
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=swarm-auditor

# ── Ollama Configuration ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:480b-cloud

# ── Detective Model (heavy reasoning for code analysis) ──
OLLAMA_DETECTIVE_MODEL=deepseek-v3.1:671b-cloud

# ── Vision Model (Hugging Face Qwen2.5-VL) ─────────
VISION_HF_MODEL=Qwen/Qwen2.5-VL-32B-Instruct

# ── GitHub Token (for private repos) ────────────────
# GITHUB_TOKEN=
